---
// ... 保持原有 import 不变
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	id: string;
	// ... 其他 Props
}

const { id, name, cover, description, date, location, tags, photoCount } =
	Astro.props;

// 建议在这里处理一下 base 路径，确保拼接时不会出现双斜杠
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const albumUrl = `${base}/gallery/${id}/`;
---

<a
  href={albumUrl}
  data-tags={tags?.join(",") || ""}
  class="album-card group relative block overflow-hidden rounded-xl transition-all duration-300 hover:shadow-lg hover:scale-[1.02]"
>
  ...
</a>